addons/lua-gdextension/build/

# SQLite GDExtension binaries (跑 ./scripts/install-sqlite-gdextension 重新拉)
addons/godot-sqlite/bin/

# Node backend
backend/node_modules/
backend/dist/
backend/.env
backend/.env.local
backend/*.log
*.log
*.db
*.sqlite
*.sqlite3
backend/data/state.db
backend/data/state.db-journal
backend/data/state.db-wal
backend/data/state.db-shm
backend/data/archive/
