# Godot 4+ specific ignores
.godot/
**/.godot/
/android/

# macOS
.DS_Store
**/.DS_Store

# Local editor/agent settings
.claude/
.codex/
.cursor/

# Local environment and secrets
.env
.env.*
!.env.example
!**/.env.example

# Vendor / third-party (手工下载，看 third-party/README.md)
