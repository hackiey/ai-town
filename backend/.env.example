NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# SQLite 数据库文件路径（相对 backend/ 进程 cwd）。Godot server 后续直连时也读这个路径。
DB_PATH=./data/state.db

# Agent brain models. Uses pi-mono model/provider shapes: provider:model[/reasoning].
# Reasoning can be off, minimal, low, medium, high, or xhigh, e.g. openai:gpt-5.4/xhigh.
# Provider-specific API keys follow pi-mono conventions, e.g. ANTHROPIC_API_KEY or OPENAI_API_KEY.
AGENT_ENABLED=false
AGENT_AVAILABLE_MODELS=
# AGENT_AVAILABLE_MODELS=openai:gpt-5.4/xhigh,anthropic:claude-sonnet-4-5/medium
# AGENT_DEFAULT_MODEL=openai:gpt-5.4/xhigh
# AGENT_MODEL_OVERRIDES=npc_blacksmith=anthropic:claude-sonnet-4-5/medium,town_1:npc_guard=openai:gpt-5.4/high

# Custom providers are JSON, either an array or an object keyed by provider name.
# Unknown custom providers default to the openai-completions API unless "api" is supplied.
# AGENT_CUSTOM_PROVIDERS_JSON={"local":{"api":"openai-completions","baseUrl":"http://127.0.0.1:11434/v1","apiKeyEnv":"LOCAL_LLM_API_KEY","reasoning":false}}
# DashScope Qwen thinking uses enable_thinking instead of reasoning_effort; dashscope URLs are auto-detected.
# AGENT_CUSTOM_PROVIDERS_JSON={"dashscope":{"api":"openai-completions","baseUrl":"https://dashscope.aliyuncs.com/compatible-mode/v1","apiKeyEnv":"DASHSCOPE_API_KEY","reasoning":true}}
# AGENT_AVAILABLE_MODELS=dashscope:qwen-plus-latest
# AGENT_DEFAULT_MODEL=dashscope:qwen-plus-latest
AGENT_MAX_TOOL_CALLS_PER_TURN=2

# Headless godot server uses this token when connecting to /ws/town-runtime.
# Player clients no longer hold this token (the runtime is now a separate process).
# Replace in every shared or deployed environment.
TOWN_RUNTIME_TOKEN=dev-headless-only-token
