{
  "name": "ai-games-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "tsx src/index.ts",
    "worker:dev": "tsx src/worker.ts",
