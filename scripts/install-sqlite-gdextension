#!/usr/bin/env bash
# Download + install 2shady4u/godot-sqlite binaries for current platform.
# 升级版本：改下面 VERSION 一处。
#
# Usage:
#   ./scripts/install-sqlite-gdextension              # 当前平台 (auto-detect)
#   ./scripts/install-sqlite-gdextension --all        # 全部平台 (CI / 跨平台 dev)
#   ./scripts/install-sqlite-gdextension --force      # 已存在也覆盖

set -euo pipefail

VERSION="v4.7"
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ADDON_DIR="$ROOT_DIR/addons/godot-sqlite"
BIN_DIR="$ADDON_DIR/bin"
BIN_URL="https://github.com/2shady4u/godot-sqlite/releases/download/${VERSION}/bin.zip"
DEMO_URL="https://github.com/2shady4u/godot-sqlite/releases/download/${VERSION}/demo.zip"

ALL_PLATFORMS=0
FORCE=0
for arg in "$@"; do
  case "$arg" in
    --all)   ALL_PLATFORMS=1 ;;
    --force) FORCE=1 ;;
    -h|--help)
      sed -n '2,9p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    *) echo "unknown arg: $arg"; exit 1 ;;
  esac
done

case "$(uname -s)" in
  Darwin)              PLATFORM="macos" ;;
  Linux)               PLATFORM="linux" ;;
  MINGW*|CYGWIN*|MSYS*) PLATFORM="windows" ;;
  *) echo "unknown OS $(uname -s); use --all to install all platforms"; exit 1 ;;
esac

if [ "$FORCE" = "0" ] && [ -f "$ADDON_DIR/gdsqlite.gdextension" ] && [ -d "$BIN_DIR" ] && [ -n "$(ls -A "$BIN_DIR" 2>/dev/null)" ]; then
  echo "godot-sqlite ${VERSION} already installed at $ADDON_DIR (use --force to reinstall)"
  exit 0
fi

mkdir -p "$ADDON_DIR" "$BIN_DIR"
TMP_DIR="$(mktemp -d)"
trap "rm -rf $TMP_DIR" EXIT

echo "downloading bin.zip ..."
curl -fSL "$BIN_URL" -o "$TMP_DIR/bin.zip"
echo "downloading demo.zip (for .gdextension manifest) ..."
curl -fSL "$DEMO_URL" -o "$TMP_DIR/demo.zip"

# bin.zip 解压所有平台二进制
unzip -q -o "$TMP_DIR/bin.zip" -d "$TMP_DIR"
# .gdextension 清单只在 demo.zip 里
unzip -q -o "$TMP_DIR/demo.zip" "demo/addons/godot-sqlite/gdsqlite.gdextension" "demo/addons/godot-sqlite/gdsqlite.gdextension.uid" -d "$TMP_DIR"
cp "$TMP_DIR/demo/addons/godot-sqlite/gdsqlite.gdextension" "$ADDON_DIR/"
cp "$TMP_DIR/demo/addons/godot-sqlite/gdsqlite.gdextension.uid" "$ADDON_DIR/" 2>/dev/null || true

# 选择性拷贝当前平台的 binary（--all 全拷）
copy_bins() {
  local pattern="$1"
  find "$TMP_DIR/bin" -maxdepth 2 -name "$pattern" -print0 | while IFS= read -r -d '' src; do
    cp -R "$src" "$BIN_DIR/"
  done
}

if [ "$ALL_PLATFORMS" = "1" ]; then
  cp -R "$TMP_DIR"/bin/* "$BIN_DIR/"
  echo "installed all platform binaries to $BIN_DIR"
else
  case "$PLATFORM" in
    macos)
      # macos build 是 .framework 目录
      copy_bins "libgdsqlite.macos.template_debug.framework"
      copy_bins "libgdsqlite.macos.template_release.framework"
      ;;
    linux)
      copy_bins "libgdsqlite.linux.template_*.x86_64.so"
      copy_bins "libgdsqlite.linux.template_*.arm64.so"
      ;;
    windows)
      copy_bins "libgdsqlite.windows.template_*.x86_64.dll"
      ;;
  esac
  echo "installed $PLATFORM binaries to $BIN_DIR"
fi

echo "done. addons/godot-sqlite is ready; godot 编辑器重新打开项目即可看到 SQLite 类型。"
