#!/usr/bin/env bash
# Download + install gilzoide/lua-gdextension binaries for current platform.
# 升级版本：改下面 VERSION 一处。
#
# Usage:
#   ./scripts/install-lua-gdextension              # 当前平台 (auto-detect)
#   ./scripts/install-lua-gdextension --all        # 全部平台 (CI / 跨平台 dev)
#   ./scripts/install-lua-gdextension --force      # 已存在也覆盖

set -euo pipefail

VERSION="0.8.0"
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ADDON_DIR="$ROOT_DIR/addons/lua-gdextension"
BUILD_DIR="$ADDON_DIR/build"
URL="https://github.com/gilzoide/lua-gdextension/releases/download/${VERSION}/lua-gdextension.zip"

ALL_PLATFORMS=0
FORCE=0
for arg in "$@"; do
  case "$arg" in
    --all)   ALL_PLATFORMS=1 ;;
    --force) FORCE=1 ;;
    -h|--help)
      sed -n '2,9p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    *) echo "unknown arg: $arg"; exit 1 ;;
  esac
done

# Detect platform
case "$(uname -s)" in
  Darwin)              PLATFORM="macos" ;;
  Linux)               PLATFORM="linux" ;;
  MINGW*|CYGWIN*|MSYS*) PLATFORM="windows" ;;
  *) echo "unknown OS $(uname -s); use --all to install all platforms"; exit 1 ;;
esac

if [ ! -f "$ADDON_DIR/luagdextension.gdextension" ]; then
  echo "error: $ADDON_DIR/luagdextension.gdextension missing — addon stub files not in repo?"
  exit 1
fi

if [ -d "$BUILD_DIR" ] && [ "$FORCE" -eq 0 ]; then
  echo "[install-lua-gdextension] $BUILD_DIR exists; pass --force to reinstall"
  exit 0
fi

TMP=$(mktemp -d)
trap "rm -rf $TMP" EXIT

echo "[install-lua-gdextension] downloading v${VERSION}..."
curl -fsSL "$URL" -o "$TMP/lua-gdext.zip"

mkdir -p "$BUILD_DIR"

if [ "$ALL_PLATFORMS" -eq 1 ]; then
  echo "[install-lua-gdextension] extracting all platforms..."
  unzip -o -q "$TMP/lua-gdext.zip" "addons/lua-gdextension/build/*" -d "$TMP/extract"
else
  echo "[install-lua-gdextension] extracting platform=${PLATFORM}..."
  # 只解压 .gdignore + 当前平台的 binaries
  unzip -o -q "$TMP/lua-gdext.zip" \
    "addons/lua-gdextension/build/.gdignore" \
    "addons/lua-gdextension/build/libluagdextension.${PLATFORM}.*" \
    -d "$TMP/extract"
fi

# 把 build/ 下所有内容（含隐藏文件）移到目标位置
cp -R "$TMP/extract/addons/lua-gdextension/build/." "$BUILD_DIR/"

echo "[install-lua-gdextension] installed:"
ls -lh "$BUILD_DIR" | tail -n +2 | awk '{ printf "  %s  %s\n", $5, $NF }'
echo "[install-lua-gdextension] done. open Godot editor once to refresh class cache."
